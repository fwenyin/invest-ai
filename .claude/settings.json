{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python:*)",
      "Bash(bash scripts/install.sh)",
      "Bash(bash scripts/run_session.sh:*)",
      "Bash(python scripts/gen_schedule.py:*)",
      "mcp__to-the-moon-data__*",
      "Write(reports/**)",
      "Edit(reports/**)",
      "Write(portfolio/**)",
      "Edit(portfolio/**)",
      "Write(backtest/results/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./config/.env)",
      "Read(./**/*.key)"
    ]
  }
}
