# ── Copy this file to .env in the repo root and fill in your values ──
# cp config/.env.example .env
# The .env file is gitignored — your keys stay local.

# Finnhub free tier: https://finnhub.io/register  (stocks + FX + news + econ calendar)
FINNHUB_API_KEY=

# Bottom Up Bulletin — read via your logged-in Substack session (no private RSS
# exists for paid text newsletters). Two values:
#   SUBSTACK_PUBLICATION = the <name> in <name>.substack.com (e.g. thepopularinvestor)
#   SUBSTACK_SESSION_COOKIE = value of the `substack.sid` cookie from your browser
#     (log in -> DevTools -> Application -> Cookies -> substack.com -> copy substack.sid).
#     Treat it like a password. It expires every few weeks; refresh when paid posts
#     start coming back as previews.
SUBSTACK_PUBLICATION=thepopularinvestor
SUBSTACK_SESSION_COOKIE=

# Your starting account equity (USD) — used for position-sizing math.
# Keep this in sync with config/risk_rules.yaml -> account.equity
ACCOUNT_EQUITY=10000
